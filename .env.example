# Volcengine / Doubao podcast TTS
VOLCENGINE_APP_ID=your-app-id
VOLCENGINE_ACCESS_TOKEN=your-access-token
VOLCENGINE_APP_KEY=your-app-key

# OpenAI-compatible LLM endpoint
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Input files
BOOK_PATH=./测试书籍/蛤蟆先生去看心理医生 (（英）罗伯特•戴博德) (z-library.sk, 1lib.sk, z-lib.sk).pdf
REVIEWS_PATH=./测试书籍/相关评论三条.txt
TOC_PATH=./测试书籍/蛤蟆先生去看心理医生目录.txt

# Optional paths
VOICE_MAP_PATH=./src/config/voice_map.json
OUTPUT_DIR=./output
TEMP_DIR=./temp

# Audio stage behavior
SKIP_EXISTING_AUDIO=true
AUDIO_RETRY_DELAY_MS=3000
