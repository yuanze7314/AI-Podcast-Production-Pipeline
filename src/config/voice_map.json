/**
 * ============================================================================
 * 播客声音映射配置
 * ============================================================================
 *
 * 功能概述：
 * 本配置文件定义了播客中使用的角色声音映射。
 * 包括：
 * - 角色信息（名称、声音ID、描述）
 * - 音频配置（格式、采样率、语速）
 * - 播放设置（背景音乐、水印等）
 *
 * ============================================================================
 * 角色设计说明：
 * ============================================================================
 *
 * 本播客采用"双人对话"模式：
 *
 * Alice（咪仔同学）:
 *   - 声音：年轻女性，活泼开朗
 *   - 定位：好奇的提问者，代表听众
 *   - 功能：引出话题、追问、表达共鸣
 *
 * Dr.Ye（叶博士）:
 *   - 声音：成熟男性，睿智沉稳
 *   - 定位：睿智的回答者，代表专家
 *   - 功能：解释、分析、给出建议
 *
 * ============================================================================
 * 声音ID说明：
 * ============================================================================
 *
 * 声音ID命名规则：
 * zh_{性别}_{名称}_v2_{系列}_{引擎}_tts
 *
 * 示例：
 * zh_female_mizaitongxue_v2_saturn_bigtts
 *   - zh: 中文
 *   - female: 女性
 *   - mizaitongxue: 咪仔同学
 *   - v2: 第二版本
 *   - saturn: 土星系列
 *   - bigtts: 火山引擎TTS
 *
 * ============================================================================
 * 可选声音列表（豆包官方）：
 * ============================================================================
 *
 * dayi/mizai 系列（推荐配对）：
 *   - zh_female_mizaitongxue_v2_saturn_bigtts  # 咪仔同学
 *   - zh_male_dayixiansheng_v2_saturn_bigtts   # 大衣先生
 *
 * 刘飞和潇磊 系列：
 *   - zh_male_liufei_v2_saturn_bigtts         # 刘飞
 *   - zh_male_xiaolei_v2_saturn_bigtts        # 潇磊
 *
 * @module voice-map
 */

{
  /**
   * 角色配置
   *
   * 定义播客中的说话角色。
   */
  "speakers": {
    /**
     * Alice - 提问者角色
     */
    "Alice": {
      /**
       * 豆包声音ID
       * 使用官方推荐的咪仔同学声音
       */
      "voice_id": "zh_female_mizaitongxue_v2_saturn_bigtts",

      /**
       * 显示名称
       */
      "name": "咪仔同学",

      /**
       * 角色描述
       */
      "description": "年轻女性，活泼开朗，善于引导和提问"
    },

    /**
     * Dr.Ye - 回答者角色
     */
    "Dr_Ye": {
      /**
       * 豆包声音ID
       * 使用官方推荐的大衣先生声音
       */
      "voice_id": "zh_male_dayixiansheng_v2_saturn_bigtts",

      /**
       * 显示名称
       */
      "name": "大衣先生",

      /**
       * 角色描述
       */
      "description": "成熟男性，睿智沉稳，擅长分析和解答"
    }
  },

  /**
   * 音频配置
   *
   * 定义输出音频的技术参数。
   */
  "audio_config": {
    /**
     * 音频格式
     * 推荐使用 mp3，兼容性好
     */
    "format": "mp3",

    /**
     * 采样率
     * 24000 = 24kHz，CD音质是44.1kHz
     */
    "sample_rate": 24000,

    /**
     * 语速
     * 0 = 正常速度
     * 负值减速，正值加速
     * 范围：-50 到 100
     */
    "speech_rate": 0
  },

  /**
   * 播放设置
   */
  "settings": {
    /**
     * 是否使用开头背景音乐
     * true: 添加开场音乐
     * false: 无开场音乐
     */
    "use_head_music": false,

    /**
     * 是否使用结尾背景音乐
     */
    "use_tail_music": false,

    /**
     * 是否随机角色顺序
     * true: 随机决定谁先开始说话
     * false: 按配置顺序
     */
    "random_order": false,

    /**
     * 是否添加AI生成水印
     * true: 在音频中添加水印标识
     * false: 不添加
     */
    "aigc_watermark": false
  }
}
